{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User profile photo URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email"]
    },
    "Blob": {
      "title": "Blob",
      "description": "A saved SVG blob configuration",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner user ID" },
        "name": { "type": "string", "description": "Name of the blob" },
        "path": { "type": "string", "description": "SVG path data" },
        "color": { "type": "string", "description": "Hex color code" },
        "complexity": { "type": "number", "description": "Complexity slider value" },
        "contrast": { "type": "number", "description": "Contrast slider value (mapped from randomness)" },
        "seed": { "type": "number", "description": "Random seed used" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["uid", "path", "color"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/blobs/{blobId}": {
      "schema": "Blob",
      "description": "Saved blobs"
    }
  }
}
